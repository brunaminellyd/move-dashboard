<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>MOVE Dashboard</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    body{
      background:#07070f;
      color:white;
      font-family:Arial;
      padding:30px;
    }

    .card{
      background:#111020;
      border:1px solid rgba(255,255,255,0.08);
      border-radius:20px;
      padding:20px;
    }
  </style>
</head>

<body>

<h1 style="font-size:32px;font-weight:bold;margin-bottom:30px;">
Dashboard MOVE Marketing
</h1>

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:30px;">

  <div class="card">
    <h3>Conteúdos do mês</h3>
    <h1 style="font-size:42px;">47</h1>
  </div>

  <div class="card">
    <h3>Publicados</h3>
    <h1 style="font-size:42px;color:#34d399;">23</h1>
  </div>

  <div class="card">
    <h3>Pendentes</h3>
    <h1 style="font-size:42px;color:#fbbf24;">06</h1>
  </div>

  <div class="card">
    <h3>Atrasados</h3>
    <h1 style="font-size:42px;color:#f87171;">03</h1>
  </div>

</div>

<div class="card">
  <canvas id="grafico"></canvas>
</div>

<script>

const ctx = document.getElementById('grafico');

new Chart(ctx, {
  type: 'bar',
  data: {
    labels: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai'],
    datasets: [{
      label: 'Conteúdos',
      data: [38,42,35,51,47]
    }]
  }
});

</script>

</body>
</html>
